# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
RUST_LOG=debug

# ── Market Data ───────────────────────────────────────────────────────────────
# Place the downloaded Kaggle CSV here:
#   data/ticks.csv
# The CSV must have columns:
#   timestamp, bid_price1, ask_price1, bid_size1, ask_size1,
#   bid_price2, ask_price2, bid_size2, ask_size2, ... up to level 10
CSV_PATH=data/ticks_small.csv
PLAYBACK_SPEED=100.0            # 1.0 = real-time, 100.0 = 100x faster

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
